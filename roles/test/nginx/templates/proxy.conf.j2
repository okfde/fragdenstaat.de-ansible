server {
    listen 80;
    listen [::]:80;

    listen 443 ssl;
    listen [::]:443 ssl;

    server_name {{ item | replace('-tst.okfn.de', '') }}.test.zerschlagdenstaat.de
    {% for domain in hostvars[item].https_domains %}
    {% if domain[0] != 'sentry.test.zerschlagdenstaat.de' %}
            {{ domain[0] }}
    {% endif %}
    {% endfor %}
            ;
    proxy_ssl_server_name on;

{% if item == 'brooke-tst.okfn.de' %}
    location /ws/ {
        allow 10.9.0.0/25;
        allow fc00::1/121;
        deny all;

        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-Proto  $scheme;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        set_real_ip_from {{ host_data.site_ipv4 }};
        real_ip_header X-Real-IP;
        real_ip_recursive on;

        proxy_pass https://{{ hostvars[item].host_data.site_ipv4 }};
        proxy_pass_header X-CSRFToken;
    }
{% endif %}

    location / {
        allow 10.9.0.0/25;
        allow fc00::1/121;

        # IPS from https://stripe.com/files/ips/ips_webhooks.txt
        # TODO scope to webhook URLs
        allow 3.18.12.63;
        allow 3.130.192.231;
        allow 13.235.14.237;
        allow 13.235.122.149;
        allow 18.211.135.69;
        allow 35.154.171.200;
        allow 52.15.183.38;
        allow 54.88.130.119;
        allow 54.88.130.237;
        allow 54.187.174.169;
        allow 54.187.205.235;
        allow 54.187.216.72;
        allow 35.157.207.129;
        allow 3.69.109.8;
        allow 3.120.168.93;

        deny all;

        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-Proto  $scheme;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        set_real_ip_from {{ host_data.site_ipv4 }};
        real_ip_header X-Real-IP;
        real_ip_recursive on;

        proxy_pass https://{{ hostvars[item].host_data.site_ipv4 }};
        proxy_pass_header X-CSRFToken;
    }
}
