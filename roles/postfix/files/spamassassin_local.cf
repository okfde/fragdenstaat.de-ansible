# Set required score (default is 5.0)
required_score 3.0

# Add headers to mark spam
add_header spam Flag _YESNOCAPS_
add_header all Status _YESNO_, score=_SCORE_ required=_REQD_ tests=_TESTS_ autolearn=_AUTOLEARN_ version=_VERSION_

# Enable or disable rules as needed
rewrite_header Subject [SPAM]

# Enable autolearn
use_auto_learn 1
auto_learn_threshold_spam 4.0
auto_learn_threshold_ham -2.0

# Use network based checks
use_dcc 1
use_pyzor 1
use_razor2 1

# Ensure the built-in ZEN check is enabled and scored
score RBL_SPAMHAUS_ZEN 3.0

# Optional: Score sublists individually (if enabled in SpamAssassin)
# score RBL_SPAMHAUS_SBL 2.5
# score RBL_SPAMHAUS_XBL 1.5
# score RBL_SPAMHAUS_PBL 0.5

# Custom Email/Domain Blacklists
blacklist_from spammer@example.com
blacklist_from *@spam-domain.net
blacklist_from *@*.bad-mailer.org

# Reduce timeout for DNSBL checks if needed
dns_timeout 15

# Adding Other Free DNSBLs (Optional)
# ———–——–——–——–
# While ZEN is sufficient, you can add other reputable free lists.
# Example: Invaluement Project (ivmURI)

# header      RBL_IVM_URI    eval:check_uri_rbl('ivmURI')
# describe    RBL_IVM_URI    Sender in Invaluement URI RBL
# score       RBL_IVM_URI    2.0
